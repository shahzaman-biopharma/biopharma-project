{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/telegram.js": { "maxDuration": 60 },
    "api/cron-reports.js": { "maxDuration": 300 }
  },
  "crons": [
    {
      "path": "/api/cron-reports",
      "schedule": "0 3 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
